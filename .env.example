# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=nft_auction_user
DB_PASSWORD=nft_auction_123
DB_NAME=nft_auction

# App
APP_ENV=development
APP_PORT=9080
JWT_SECRET_KEY=your-secret-key-change-in-production

# Logs
LOG_DIR=./logs
LOG_LEVEL=info

# Blockchain (optional, omit to run without chain reads)
# HTTP RPC — used for contract reads (getAuction, tokenURI, etc.)
RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
# WebSocket RPC — required for real-time event listener (SubscribeFilterLogs)
# Infura:  wss://sepolia.infura.io/ws/v3/YOUR_PROJECT_ID
# Alchemy: wss://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
WS_RPC_URL=wss://sepolia.infura.io/ws/v3/YOUR_PROJECT_ID
AUCTION_CONTRACT_ADDRESS=0x...
NFT_CONTRACT_ADDRESS=0x...
# 拍卖合约部署区块；事件监听器从此块开始补扫，减少首次同步量（可选）
# AUCTION_DEPLOY_BLOCK=5500000
# NFT 合约部署区块；必须设置，否则从创世块扫易触发 RPC internal error（长链或限流时）
# NFT_DEPLOY_BLOCK=5500000

# NFT 元数据/图片拉取：IPFS 网关（用于将 ipfs:// 转为 HTTP）
# 图片慢时可换更快的网关，例如 Cloudflare：https://cloudflare-ipfs.com/ipfs/
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
